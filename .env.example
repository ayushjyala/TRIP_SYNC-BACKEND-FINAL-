# ──────────────────────────────────────────────────
#  Trip Sync — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit the real .env file to version control.
# ──────────────────────────────────────────────────

# MongoDB connection URI
# Local:  mongodb://localhost:27017/tripsync
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tripsync?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/tripsync

# Server port (Render / Railway will set PORT automatically)
PORT=3000

# Set to "production" on live servers for cleaner error messages
NODE_ENV=development
